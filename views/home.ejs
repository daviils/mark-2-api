<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Home</title>
    <link rel="stylesheet" href="/css/tailwind.css" />
  </head>
  <body class="bg-slate-50 text-slate-900">
    <main class="mx-auto max-w-3xl px-6 py-16">
      <h1 class="text-3xl font-semibold">Olá <%= name %></h1>
      <p class="mt-2 text-slate-600">Nest renderizando HTML com Tailwind.</p>

      <section class="mt-8 rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-xl font-medium">Buscar tópicos</h2>

        <form id="topic-search-form" class="mt-4 flex gap-3">
          <input
            id="keyword"
            name="keyword"
            type="text"
            placeholder="Digite uma palavra-chave"
            class="w-full rounded-md border border-slate-300 px-3 py-2 outline-none focus:border-slate-500"
          />
          <button
            type="submit"
            class="rounded-md bg-slate-900 px-4 py-2 font-medium text-white hover:bg-slate-700"
          >
            Buscar
          </button>
        </form>

        <p id="feedback" class="mt-3 text-sm text-slate-600"></p>
        <ul id="results" class="mt-4 space-y-3"></ul>
      </section>
    </main>

    <script src="/js/home-modal.js" defer></script>
    <script src="/js/home.js" defer></script>
  </body>
</html>
